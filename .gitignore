# ══════════════════════════════════════════════════
#  Eden Project — 루트 .gitignore
#  (프로젝트 최상단, backend/ frontend/ 와 같은 위치에 .gitignore 로 저장)
# ══════════════════════════════════════════════════

# ── 🔑 비밀키 / 환경변수 (절대 커밋 금지) ──────────
.env
.env.*
!.env.example          # 예시 파일은 올림 (키 값 없는 템플릿)
*.pem
*.key
secrets.json

# ── 📦 대용량 데이터 (GitHub 100MB 제한 초과) ──────
# chroma_db: 152MB — 팀 원본 zip으로 공유, 커밋 금지
backend/data/chroma_db/
# 성경 원본 JSON: 6.8MB — 팀 원본으로 공유
backend/data/bible_structured.json
# 사용자 DB: 개인정보 + 자동 생성
backend/data/users.json
# 기타 데이터
*.zip
*.sqlite3
*.bin
*.pickle
*.pkl

# ── 🐍 Python ─────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.venv/
venv/
env/
ENV/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
dist/
build/

# ── ⚛️ Node / Vite ────────────────────────────────
node_modules/
frontend/node_modules/
dist/
dist-ssr/
frontend/dist/
.vite/
frontend/.vite/
*.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
logs/
*.log

# ── 🖥️ OS / 에디터 ────────────────────────────────
.DS_Store
__MACOSX/
Thumbs.db
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo